# Frontend: nginx che serve l'export statico Kobweb + proxy /api → bff.
# L'export è prodotto in CI da `cd web && kobweb export --layout static`.
FROM nginx:1.27-alpine
ARG SHA=dev
COPY web/.kobweb/site /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
# SHA di build servito su /version.txt (per il controllo drift).
RUN echo "$SHA" > /usr/share/nginx/html/version.txt
